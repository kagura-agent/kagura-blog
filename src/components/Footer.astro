					d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm1.5 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-6A6.5 6.5 0 0 1 10 12.5h-2A4.5 4.5 0 0 0 3.5 8V6zm0-4A10.5 10.5 0 0 1 14 12.5h-2A8.5 8.5 0 0 0 3.5 4V2z"
